---
import { AuthMenu } from './AuthMenu';

const domain = import.meta.env.PUBLIC_DOMAIN ?? 'recipes';
const isGeo = domain === 'geo';
const currentPath = Astro.url.pathname;

const property = isGeo
  ? {
      label: 'Atlas',
      description: 'The world, dish by dish',
      host: 'gustale.com',
      href: 'https://gustale.com/',
    }
  : {
      label: 'Recipes',
      description: 'A living culinary archive',
      host: 'gustale.recipes',
      href: 'https://gustale.recipes/',
    };

const otherProperty = isGeo
  ? {
      label: 'Recipes',
      description: 'A living culinary archive',
      host: 'gustale.recipes',
      href: 'https://gustale.recipes/',
      icon: 'book',
    }
  : {
      label: 'Atlas',
      description: 'The world, dish by dish',
      host: 'gustale.com',
      href: 'https://gustale.com/',
      icon: 'globe',
    };

const primaryNav = isGeo
  ? [
      { label: 'Atlas', href: '/', active: currentPath === '/' },
      { label: 'Families', href: '/families', active: currentPath.startsWith('/families') },
      { label: 'Lineages', href: '/lineages', active: currentPath.startsWith('/lineages') },
      { label: 'About Gustale', href: '/about', active: currentPath.startsWith('/about') },
    ]
  : [
      { label: 'Recipes', href: '/dishes', active: currentPath.startsWith('/dishes') },
      { label: 'Ingredients', href: '/dishes', active: false },
      { label: 'Collections', href: '/about', active: currentPath.startsWith('/about') },
    ];

const searchRows = isGeo
  ? [
      { group: 'Dishes', label: 'Khachapuri', meta: 'Georgia', href: '/dishes/khachapuri', icon: 'KH' },
      { group: 'Dishes', label: 'Pho', meta: 'Vietnam', href: '/dishes/pho', icon: 'PH' },
      { group: 'Places', label: 'Morocco', meta: 'Atlas', href: '/map', icon: 'MO' },
    ]
  : [
      { group: 'Dishes', label: 'Tagine', meta: 'Morocco', href: '/dishes/tagine', icon: 'TA' },
      { group: 'Ingredients', label: 'Saffron', meta: 'Pantry', href: '/dishes', icon: 'SA' },
      { group: 'Collections', label: 'Egg dishes', meta: 'Family', href: '/families', icon: 'EG' },
    ];
---

<header id="site-header" class="site-header sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-3 px-4 md:gap-6">
    <div class="relative flex shrink-0 items-center gap-2">
      <a href="/" class="font-display flex items-baseline text-[22px] font-semibold leading-none text-slate-900">
        gustale<span class="text-emerald-600">.</span>
      </a>

      <button
        id="propBtn"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        class="group inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 py-1 pl-2.5 pr-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-100"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        <span>{property.label}</span>
        <svg class="h-3.5 w-3.5 text-slate-400 transition group-aria-expanded:rotate-180" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div id="propPop" class="pop absolute left-0 top-12 z-50 w-[300px] rounded-2xl border border-slate-200 bg-white p-1.5 shadow-xl shadow-slate-900/10" hidden>
        <p class="px-3 pb-1.5 pt-2 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Switch property</p>
        <a href={property.href} class="flex w-full items-start gap-3 rounded-xl px-3 py-2.5 text-left transition hover:bg-slate-50">
          <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-emerald-50 text-emerald-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5-2.7-2.5-15.3 0-18" stroke-linecap="round"></path>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="flex items-center gap-2 text-sm font-semibold text-slate-900">{property.label} <span class="text-emerald-600">✓</span></span>
            <span class="block text-[13px] leading-snug text-slate-500">{property.description} · {property.host}</span>
          </span>
        </a>
        <a href={otherProperty.href} class="flex w-full items-start gap-3 rounded-xl px-3 py-2.5 text-left transition hover:bg-slate-50">
          <span class:list={['mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg', otherProperty.icon === 'book' ? 'bg-amber-50 text-amber-600' : 'bg-emerald-50 text-emerald-600']}>
            {otherProperty.icon === 'book' ? (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <path d="M5 4h11a3 3 0 0 1 3 3v13H8a3 3 0 0 1-3-3V4z"></path>
                <path d="M8 8h7M8 12h7" stroke-linecap="round"></path>
              </svg>
            ) : (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5-2.7-2.5-15.3 0-18" stroke-linecap="round"></path>
              </svg>
            )}
          </span>
          <span class="min-w-0">
            <span class="block text-sm font-semibold text-slate-900">{otherProperty.label}</span>
            <span class="block text-[13px] leading-snug text-slate-500">{otherProperty.description} · {otherProperty.host}</span>
          </span>
        </a>
      </div>
    </div>

    <nav class="d-only ml-1 flex items-center gap-6 text-[15px] font-medium text-slate-600" aria-label="Primary">
      {primaryNav.map((item) => (
        <a href={item.href} class="navlink hover:text-slate-900" data-active={item.active ? 'true' : 'false'}>{item.label}</a>
      ))}
    </nav>

    <div class="d-only relative ml-auto w-full max-w-sm">
      <div class="group relative">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
        </svg>
        <input id="siteSearch" type="text" autocomplete="off" placeholder="Search dishes, ingredients, places..." class="w-full rounded-full border border-slate-200 bg-slate-50 py-2 pl-9 pr-9 text-sm text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-emerald-300 focus:bg-white focus:ring-4 focus:ring-emerald-500/10" />
        <kbd class="absolute right-2.5 top-1/2 -translate-y-1/2 rounded border border-slate-200 bg-white px-1.5 py-0.5 text-[11px] text-slate-400">/</kbd>
      </div>
      <div id="searchPop" class="pop absolute left-0 right-0 top-12 z-50 overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl shadow-slate-900/10" hidden>
        <div class="max-h-[60vh] overflow-y-auto pb-2">
          {['Dishes', 'Ingredients', 'Places', 'Collections'].map((group) => (
            searchRows.filter((row) => row.group === group).length > 0 && (
              <>
                <p class="px-3 pb-1 pt-2.5 text-[11px] font-semibold uppercase tracking-wider text-slate-400">{group}</p>
                {searchRows.filter((row) => row.group === group).map((row) => (
                  <a href={row.href} data-search-row={`${row.label} ${row.meta}`.toLowerCase()} class="flex items-center gap-3 px-3 py-2 hover:bg-slate-50">
                    <span class="grid h-8 w-8 place-items-center rounded-md bg-slate-100 text-[11px] font-semibold text-slate-500">{row.icon}</span>
                    <span class="text-sm font-medium text-slate-800">{row.label}</span>
                    <span class="ml-auto text-xs text-slate-400">{row.meta}</span>
                  </a>
                ))}
              </>
            )
          ))}
          <p id="searchEmpty" class="hidden px-3 py-6 text-center text-sm text-slate-400">No matches</p>
        </div>
      </div>
    </div>

    <div class="d-only flex shrink-0 items-center gap-2">
      <a href="/dishes/new" class="inline-flex items-center gap-1.5 rounded-full bg-emerald-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700">
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M10 4v12M4 10h12" stroke-linecap="round"></path>
        </svg>
        Add a dish
      </a>
      <AuthMenu client:load />
    </div>

    <div class="m-only ml-auto flex items-center gap-1">
      <button id="mSearchBtn" type="button" aria-label="Search" class="grid h-10 w-10 place-items-center rounded-full text-slate-600 transition hover:bg-slate-100">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
        </svg>
      </button>
      <button id="burger" type="button" aria-label="Menu" aria-expanded="false" class="grid h-10 w-10 place-items-center rounded-full text-slate-700 transition hover:bg-slate-100">
        <svg data-menu-icon class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mSearchWrap" class="m-only overflow-hidden border-t border-slate-100" hidden>
    <div class="px-4 py-3">
      <div class="relative">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
        </svg>
        <input id="mSearch" type="text" placeholder="Search dishes, ingredients, places..." class="w-full rounded-full border border-slate-200 bg-slate-50 py-2.5 pl-9 pr-3 text-sm outline-none focus:border-emerald-300 focus:bg-white" />
      </div>
    </div>
  </div>
</header>

<div id="mobileSheet" class="sheet m-only fixed inset-x-0 z-30 origin-top border-b border-slate-200 bg-white shadow-2xl shadow-slate-900/10" data-open="false">
  <nav class="flex flex-col px-4 pt-3 text-[17px] font-medium text-slate-800" aria-label="Mobile primary">
    {primaryNav.map((item) => (
      <a href={item.href} class="flex items-center justify-between rounded-xl px-3 py-3 hover:bg-slate-50">
        <span class="flex items-center gap-3">
          <span class="grid h-5 w-5 place-items-center text-slate-400">•</span>
          {item.label}
        </span>
      </a>
    ))}
    <a href="/about" class="flex items-center justify-between rounded-xl px-3 py-3 hover:bg-slate-50">
      <span class="flex items-center gap-3">
        <svg class="h-5 w-5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <circle cx="12" cy="12" r="9"></circle>
          <path d="M12 8v5M12 16h.01" stroke-linecap="round"></path>
        </svg>
        About
      </span>
    </a>
  </nav>
  <div class="mx-4 h-px bg-slate-100"></div>
  <div class="px-4 py-3">
    <a href="/dishes/new" class="flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-[15px] font-semibold text-white">
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
        <path d="M10 4v12M4 10h12" stroke-linecap="round"></path>
      </svg>
      Add a dish
    </a>
    <div class="mt-3 flex items-center justify-between rounded-xl bg-slate-50 px-3 py-2.5">
      <span class="text-sm text-slate-600">Not signed in</span>
      <a href="/login" class="text-sm font-semibold text-emerald-700">Sign in</a>
    </div>
  </div>
  <div class="px-4 pb-4">
    <p class="px-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Property</p>
    <div class="grid grid-cols-2 gap-1.5 rounded-xl bg-slate-100 p-1">
      <a href="https://gustale.com/" class:list={['rounded-lg px-3 py-2 text-center text-sm font-medium transition', isGeo ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500']}>Atlas</a>
      <a href="https://gustale.recipes/" class:list={['rounded-lg px-3 py-2 text-center text-sm font-medium transition', !isGeo ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500']}>Recipes</a>
    </div>
  </div>
</div>

<script>
  (() => {
    const propBtn = document.getElementById('propBtn');
    const propPop = document.getElementById('propPop');
    const search = document.getElementById('siteSearch');
    const searchPop = document.getElementById('searchPop');
    const searchRows = Array.from(document.querySelectorAll('[data-search-row]'));
    const searchEmpty = document.getElementById('searchEmpty');
    const mSearchBtn = document.getElementById('mSearchBtn');
    const mSearchWrap = document.getElementById('mSearchWrap');
    const mSearch = document.getElementById('mSearch');
    const burger = document.getElementById('burger');
    const sheet = document.getElementById('mobileSheet');

    function closeMenus(except?: HTMLElement) {
      for (const el of [propPop, searchPop]) {
        if (el && el !== except) el.hidden = true;
      }
      propBtn?.setAttribute('aria-expanded', 'false');
    }

    function setSheet(open: boolean) {
      if (!sheet || !burger) return;
      sheet.dataset.open = open ? 'true' : 'false';
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      burger.innerHTML = open
        ? '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/></svg>'
        : '<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/></svg>';
    }

    function filterSearch() {
      const q = ((search as HTMLInputElement | null)?.value || '').trim().toLowerCase();
      let visible = 0;
      for (const row of searchRows) {
        const match = !q || row.getAttribute('data-search-row')?.includes(q);
        row.classList.toggle('hidden', !match);
        if (match) visible++;
      }
      searchEmpty?.classList.toggle('hidden', visible > 0);
    }

    propBtn?.addEventListener('click', (event) => {
      event.stopPropagation();
      const willOpen = !!propPop?.hidden;
      closeMenus(willOpen ? propPop : undefined);
      if (propPop) propPop.hidden = !willOpen;
      propBtn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
    });

    search?.addEventListener('focus', () => {
      closeMenus(searchPop || undefined);
      filterSearch();
      if (searchPop) searchPop.hidden = false;
    });
    search?.addEventListener('input', () => {
      filterSearch();
      if (searchPop) searchPop.hidden = false;
    });

    mSearchBtn?.addEventListener('click', () => {
      const willOpen = !!mSearchWrap?.hidden;
      if (mSearchWrap) mSearchWrap.hidden = !willOpen;
      if (willOpen) {
        setSheet(false);
        mSearch?.focus();
      }
    });

    burger?.addEventListener('click', () => {
      const willOpen = sheet?.dataset.open !== 'true';
      setSheet(willOpen);
      if (willOpen && mSearchWrap) mSearchWrap.hidden = true;
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === '/' && document.activeElement !== search && window.matchMedia('(min-width: 768px)').matches) {
        event.preventDefault();
        search?.focus();
      }
      if (event.key === 'Escape') {
        closeMenus(undefined);
        setSheet(false);
        if (mSearchWrap) mSearchWrap.hidden = true;
      }
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest('#propPop, #propBtn, #searchPop, #siteSearch')) closeMenus(undefined);
    });
  })();
</script>
