---
import { AuthMenu } from './AuthMenu';

interface NavItem {
  href: string;
  label: string;
  match: string[];
}

export interface Props {
  currentPath: string;
  domain: string;
}

const { currentPath, domain } = Astro.props;
const isGeo = domain === 'geo';
const propertyLabel = isGeo ? 'Atlas' : 'Recipes';
const propertyDescription = isGeo
  ? 'The world, dish by dish'
  : 'A living culinary archive';
const currentOrigin = isGeo ? 'https://gustale.com' : 'https://gustale.recipes';
const alternateOrigin = isGeo ? 'https://gustale.recipes' : 'https://gustale.com';
const dishSearchAction = isGeo ? 'https://gustale.recipes/dishes' : '/dishes';
const addDishHref = isGeo ? 'https://gustale.recipes/dishes/new' : '/dishes/new';

const navItems: NavItem[] = isGeo
  ? [
      { href: '/map', label: 'Atlas', match: ['/map'] },
      { href: '/about', label: 'About', match: ['/about'] },
    ]
  : [
      { href: '/dishes', label: 'Recipes', match: ['/dishes'] },
      { href: '/about', label: 'About', match: ['/about'] },
    ];

function isActive(item: NavItem) {
  return item.match.some((path) => currentPath === path || currentPath.startsWith(`${path}/`));
}
---

<header
  data-site-header
  class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/75"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center gap-3 px-4 md:gap-6">
    <div class="relative flex shrink-0 items-center gap-2">
      <a
        href="/"
        class="font-display flex items-baseline text-[22px] font-semibold leading-none tracking-tight text-slate-900 transition hover:text-emerald-700"
        aria-label={`Gustale ${propertyLabel} home`}
      >
        gustale<span class="text-emerald-600">.</span>
      </a>

      <button
        data-property-button
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        class="group inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 py-1 pl-2.5 pr-2 text-sm font-medium text-slate-700 transition hover:border-slate-300 hover:bg-slate-100"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        <span>{propertyLabel}</span>
        <svg
          class="h-3.5 w-3.5 text-slate-400 transition group-aria-expanded:rotate-180"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          aria-hidden="true"
        >
          <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </button>

      <div
        data-property-menu
        class="absolute left-0 top-12 z-50 w-[300px] rounded-2xl border border-slate-200 bg-white p-1.5 shadow-xl shadow-slate-900/10"
        hidden
      >
        <p class="px-3 pb-1.5 pt-2 text-[11px] font-semibold uppercase tracking-wider text-slate-400">
          Switch property
        </p>
        <a
          href={currentOrigin}
          class="flex w-full items-start gap-3 rounded-xl px-3 py-2.5 text-left transition hover:bg-slate-50"
          aria-current="true"
        >
          <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-emerald-50 text-emerald-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5 2.7-2.5 15.3 0 18" stroke-linecap="round"></path>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="flex items-center gap-2 text-sm font-semibold text-slate-900">
              {propertyLabel}
              <span class="rounded-full bg-emerald-50 px-1.5 py-0.5 text-[10px] uppercase tracking-wider text-emerald-700">
                Current
              </span>
            </span>
            <span class="block text-[13px] leading-snug text-slate-500">
              {propertyDescription} - {isGeo ? 'gustale.com' : 'gustale.recipes'}
            </span>
          </span>
        </a>
        <a
          href={alternateOrigin}
          class="flex w-full items-start gap-3 rounded-xl px-3 py-2.5 text-left transition hover:bg-slate-50"
        >
          <span class="mt-0.5 grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-amber-50 text-amber-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M5 4h11a3 3 0 013 3v13H8a3 3 0 01-3-3V4z"></path>
              <path d="M8 8h7M8 12h7" stroke-linecap="round"></path>
            </svg>
          </span>
          <span class="min-w-0">
            <span class="text-sm font-semibold text-slate-900">{isGeo ? 'Recipes' : 'Atlas'}</span>
            <span class="block text-[13px] leading-snug text-slate-500">
              {isGeo ? 'A living culinary archive - gustale.recipes' : 'The world, dish by dish - gustale.com'}
            </span>
          </span>
        </a>
      </div>
    </div>

    <nav class="ml-1 hidden items-center gap-6 text-[15px] font-medium text-slate-600 md:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="navlink hover:text-slate-900"
            data-active={isActive(item) ? 'true' : 'false'}
            aria-current={isActive(item) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <form action={dishSearchAction} class="relative ml-auto hidden w-full max-w-sm md:block" role="search">
      <div class="group relative">
        <svg
          class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.7"
          aria-hidden="true"
        >
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
        </svg>
        <input
          data-site-search
          name="search"
          type="search"
          autocomplete="off"
          placeholder="Search dishes, ingredients, places..."
          class="w-full rounded-full border border-slate-200 bg-slate-50 py-2 pl-9 pr-9 text-sm text-slate-800 outline-none transition placeholder:text-slate-400 focus:border-emerald-300 focus:bg-white focus:ring-4 focus:ring-emerald-500/10"
        />
        <kbd class="absolute right-2.5 top-1/2 -translate-y-1/2 rounded border border-slate-200 bg-white px-1.5 py-0.5 text-[11px] text-slate-400">
          /
        </kbd>
      </div>
    </form>

    <div class="hidden shrink-0 items-center gap-2 md:flex">
      <a
        href={addDishHref}
        class="inline-flex items-center gap-1.5 rounded-full bg-emerald-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M10 4v12M4 10h12" stroke-linecap="round"></path>
        </svg>
        Add a dish
      </a>
      <AuthMenu client:load />
    </div>

    <div class="ml-auto flex items-center gap-1 md:hidden">
      <button
        data-mobile-search-button
        type="button"
        aria-label="Search"
        class="grid h-10 w-10 place-items-center rounded-full text-slate-600 transition hover:bg-slate-100"
      >
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
        </svg>
      </button>
      <button
        data-mobile-menu-button
        type="button"
        aria-label="Menu"
        aria-expanded="false"
        class="grid h-10 w-10 place-items-center rounded-full text-slate-700 transition hover:bg-slate-100"
      >
        <svg data-menu-icon class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>

  <form
    data-mobile-search
    action={dishSearchAction}
    class="hidden border-t border-slate-100 px-4 py-3 md:hidden"
    role="search"
  >
    <div class="relative">
      <svg
        class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400"
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        aria-hidden="true"
      >
        <circle cx="9" cy="9" r="6"></circle>
        <path d="M14 14l3.5 3.5" stroke-linecap="round"></path>
      </svg>
      <input
        data-mobile-search-input
        name="search"
        type="search"
        placeholder="Search dishes, ingredients, places..."
        class="w-full rounded-full border border-slate-200 bg-slate-50 py-2.5 pl-9 pr-3 text-sm outline-none focus:border-emerald-300 focus:bg-white"
      />
    </div>
  </form>

  <div
    data-mobile-sheet
    class="absolute inset-x-0 top-16 z-30 hidden origin-top border-b border-slate-200 bg-white shadow-2xl shadow-slate-900/10 md:hidden"
  >
    <nav class="flex flex-col px-4 pt-3 text-[17px] font-medium text-slate-800" aria-label="Mobile primary">
      {
        navItems.map((item) => (
          <a href={item.href} class="flex items-center justify-between rounded-xl px-3 py-3 hover:bg-slate-50">
            <span class="flex items-center gap-3">
              <span class="grid h-5 w-5 place-items-center text-slate-400" aria-hidden="true">
                <svg class="h-1.5 w-1.5" viewBox="0 0 6 6" fill="currentColor">
                  <circle cx="3" cy="3" r="3"></circle>
                </svg>
              </span>
              {item.label}
            </span>
          </a>
        ))
      }
    </nav>
    <div class="mx-4 h-px bg-slate-100"></div>
    <div class="px-4 py-3">
      <a
        href={addDishHref}
        class="flex w-full items-center justify-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-[15px] font-semibold text-white"
      >
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M10 4v12M4 10h12" stroke-linecap="round"></path>
        </svg>
        Add a dish
      </a>
      <div class="mt-3 rounded-xl bg-slate-50 px-3 py-2.5">
        <AuthMenu client:load variant="mobile" />
      </div>
    </div>
    <div class="px-4 pb-4">
      <p class="px-1 pb-1.5 text-[11px] font-semibold uppercase tracking-wider text-slate-400">Property</p>
      <div class="grid grid-cols-2 gap-1.5 rounded-xl bg-slate-100 p-1">
        <a
          href="https://gustale.com"
          class={`rounded-lg px-3 py-2 text-center text-sm font-medium transition ${isGeo ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500'}`}
        >
          Atlas
        </a>
        <a
          href="https://gustale.recipes"
          class={`rounded-lg px-3 py-2 text-center text-sm font-medium transition ${!isGeo ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500'}`}
        >
          Recipes
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const header = document.querySelector('[data-site-header]');
    if (!header) return;

    const propertyButton = header.querySelector('[data-property-button]');
    const propertyMenu = header.querySelector('[data-property-menu]');
    const mobileMenuButton = header.querySelector('[data-mobile-menu-button]');
    const mobileSheet = header.querySelector('[data-mobile-sheet]');
    const mobileSearchButton = header.querySelector('[data-mobile-search-button]');
    const mobileSearch = header.querySelector('[data-mobile-search]');
    const mobileSearchInput = header.querySelector('[data-mobile-search-input]');
    const desktopSearch = header.querySelector('[data-site-search]');

    const closePropertyMenu = () => {
      if (!propertyMenu || !propertyButton) return;
      propertyMenu.hidden = true;
      propertyButton.setAttribute('aria-expanded', 'false');
    };

    const closeMobileSheet = () => {
      if (!mobileSheet || !mobileMenuButton) return;
      mobileSheet.classList.add('hidden');
      mobileMenuButton.setAttribute('aria-expanded', 'false');
      const icon = mobileMenuButton.querySelector('[data-menu-icon]');
      if (icon) {
        icon.innerHTML = '<path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>';
      }
    };

    propertyButton?.addEventListener('click', (event) => {
      event.stopPropagation();
      if (!propertyMenu) return;
      const willOpen = propertyMenu.hidden;
      propertyMenu.hidden = !willOpen;
      propertyButton.setAttribute('aria-expanded', String(willOpen));
      closeMobileSheet();
    });

    mobileMenuButton?.addEventListener('click', () => {
      if (!mobileSheet) return;
      const willOpen = mobileSheet.classList.contains('hidden');
      mobileSheet.classList.toggle('hidden', !willOpen);
      mobileMenuButton.setAttribute('aria-expanded', String(willOpen));
      const icon = mobileMenuButton.querySelector('[data-menu-icon]');
      if (icon) {
        icon.innerHTML = willOpen
          ? '<path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"></path>'
          : '<path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"></path>';
      }
      closePropertyMenu();
      mobileSearch?.classList.add('hidden');
    });

    mobileSearchButton?.addEventListener('click', () => {
      if (!mobileSearch) return;
      const willOpen = mobileSearch.classList.contains('hidden');
      mobileSearch.classList.toggle('hidden', !willOpen);
      closeMobileSheet();
      closePropertyMenu();
      if (willOpen) mobileSearchInput?.focus();
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      if (!event.target.closest('[data-property-menu], [data-property-button]')) {
        closePropertyMenu();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        closePropertyMenu();
        closeMobileSheet();
        mobileSearch?.classList.add('hidden');
      }
      if (
        event.key === '/' &&
        !event.metaKey &&
        !event.ctrlKey &&
        !event.altKey &&
        document.activeElement !== desktopSearch &&
        document.activeElement?.tagName !== 'INPUT' &&
        document.activeElement?.tagName !== 'TEXTAREA'
      ) {
        event.preventDefault();
        desktopSearch?.focus();
      }
    });
  })();
</script>
