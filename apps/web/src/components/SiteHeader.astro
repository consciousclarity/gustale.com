---
/**
 * Gustale masthead — domain-aware editorial top bar.
 *
 * Reads everything from src/lib/navigation.ts (no hardcoded link lists).
 * The thin chrome stays SSR'd here; three interactive islands hydrate on
 * top of it:
 *   - <NavSearch>  full-bleed search overlay + magnifier trigger ("/" focuses)
 *   - <MobileNav>  full-bleed mobile takeover + "Menu" trigger
 *   - <AuthMenu>   better-auth account state (desktop variant)
 *
 * The property switcher and the scroll-border signal are progressive
 * vanilla JS (small enough not to warrant an island).
 */
import { AuthMenu } from './AuthMenu';
import { NavSearch } from './NavSearch';
import { MobileNav } from './MobileNav';
import { getNavConfig, isLinkActive } from '../lib/navigation';

const domain = import.meta.env.PUBLIC_DOMAIN ?? 'recipes';
const isGeo = domain === 'geo';
const nav = getNavConfig(isGeo);
const pathname = Astro.url.pathname;
---

<header class="gnav" data-scrolled="false">
  <div class="wrap gnav-in">
    <!-- Left: wordmark · property switcher · (mobile) Menu trigger -->
    <div class="gnav-left">
      <a href="/" class="gnav-brand" aria-label="Gustale home">
        gustale<span class="gnav-period">.</span>
      </a>

      <div class="gnav-prop gnav-desktoponly">
        <button
          id="gnavPropBtn"
          type="button"
          class="gnav-prop-btn"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="gnavPropPop"
        >
          <span class="gnav-prop-dot" aria-hidden="true"></span>
          {nav.brandSub}
        </button>
        <div id="gnavPropPop" class="gnav-prop-pop" role="menu" hidden>
          <p class="gnav-prop-eyebrow">Two reading rooms</p>
          <a href={nav.current.href} class="gnav-prop-row" role="menuitem" aria-current="true">
            <span class="gnav-prop-dot" aria-hidden="true"></span>
            <span class="gnav-prop-name">{nav.current.label}</span>
            <span class="gnav-prop-meta">{nav.current.description} · {nav.current.host}</span>
          </a>
          <a href={nav.other.href} class="gnav-prop-row" role="menuitem">
            <span class="gnav-prop-arrow" aria-hidden="true">→</span>
            <span class="gnav-prop-name">{nav.other.label}</span>
            <span class="gnav-prop-meta">{nav.other.description} · {nav.other.host}</span>
          </a>
        </div>
      </div>

      <div class="gnav-mobileonly gnav-menuslot">
        <MobileNav
          client:load
          primary={nav.primary}
          current={nav.current}
          other={nav.other}
          pathname={pathname}
        />
      </div>
    </div>

    <!-- Center: primary sections (desktop) -->
    <nav class="gnav-primary gnav-desktoponly" aria-label="Primary">
      {nav.primary.map((link) =>
        link.soon ? (
          <span class="gnav-link" aria-disabled="true" title="Coming soon">{link.label}</span>
        ) : (
          <a
            href={link.href}
            class="gnav-link"
            data-active={isLinkActive(link, pathname) ? 'true' : 'false'}
            aria-current={isLinkActive(link, pathname) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ),
      )}
    </nav>

    <!-- Right: search · account -->
    <div class="gnav-right">
      <NavSearch
        client:load
        searchSeed={nav.searchSeed}
        searchPrompts={nav.searchPrompts}
        searchSuggestions={nav.searchSuggestions}
      />
      <nav class="gnav-account gnav-desktoponly" aria-label="User">
        <AuthMenu client:load variant="desktop" />
      </nav>
    </div>
  </div>
</header>

<script>
  (() => {
    const header = document.querySelector<HTMLElement>('.gnav');
    const propBtn = document.getElementById('gnavPropBtn');
    const propPop = document.getElementById('gnavPropPop');

    function setProp(open: boolean) {
      if (!propPop || !propBtn) return;
      propPop.hidden = !open;
      propBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    propBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      setProp(propPop?.hidden ?? true);
    });

    document.addEventListener('click', (e) => {
      const t = e.target;
      if (t instanceof Element && !t.closest('#gnavPropPop, #gnavPropBtn')) setProp(false);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setProp(false);
    });

    // Scroll signal: swap the bottom border weight past 80px. No blur.
    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        header?.setAttribute('data-scrolled', window.scrollY > 80 ? 'true' : 'false');
        ticking = false;
      });
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
