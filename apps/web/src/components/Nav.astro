---
import '../styles/global.css';
import { AuthMenu } from './AuthMenu';

const domain = import.meta.env.PUBLIC_DOMAIN ?? 'recipes';
const isGeo = domain === 'geo';

// The "other" domain URL — used for the cross-domain switcher
const otherDomain = isGeo ? 'https://gustale.recipes' : 'https://gustale.com';
const otherLabel   = isGeo ? 'Recipes'               : 'Atlas';

// Domain-specific link that only appears on one domain
const domainLink = isGeo
  ? { href: '/map',           label: 'Map' }
  : { href: '/dishes',        label: 'Recipes' };

// Shared links present on both domains.
// Taxonomy pages are grouped together: Families (dish form), Regions
// (geographic origin), Lineages (preparation method).
const sharedLinks = [
  { href: '/dishes',   label: 'Dishes'   },
  { href: '/families', label: 'Families' },
  { href: '/regions',  label: 'Regions'  },
  { href: '/lineages', label: 'Lineages' },
  { href: '/about',    label: 'About'    },
];

// On geo domain, filter out /dishes from shared links (Map is the geo entry point)
const links = isGeo
  ? sharedLinks.filter(l => l.href !== '/dishes')
  : sharedLinks;
---

<nav class="gst-nav" id="main-nav" data-domain={domain}>
  <div class="wrap gst-nav-in">

    <!-- Wordmark -->
    <a href="/" class="gst-brand">
      <span class="gst-wordmark">Gustale</span>
      <span class="sub">{isGeo ? 'Atlas' : 'Recipes'}</span>
    </a>

    <!-- Cross-domain switcher — slim pill top-right of wordmark -->
    <a href={otherDomain} class="domain-switch" aria-label={`Switch to ${otherLabel}`}>
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
        <path d="M3.5 2L6.5 5L3.5 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {otherLabel}
    </a>

    <!-- Primary nav links -->
    <div class="gst-navlinks" id="nav-links">
      {links.map(link => (
        <a
          href={link.href}
          class="gst-navlink"
          data-domain-link={link.href.startsWith('/') ? link.href : undefined}
        >
          {link.label}
        </a>
      ))}

      <!-- Domain-specific primary link (Map on geo, Recipes on recipes) -->
      <a href={domainLink.href} class="gst-navlink gst-navlink--domain">
        {domainLink.label}
      </a>
    </div>

    <!-- Right side: Auth + Contribute -->
    <div class="gst-navr" id="nav-right">
      <AuthMenu client:load />
      <a href="/contribute" class="btn-accent">Contribute</a>

      <!-- Mobile menu toggle -->
      <button class="nav-mobile-toggle" id="nav-mobile-toggle" aria-label="Open menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile drawer -->
  <div class="nav-mobile-drawer" id="nav-mobile-drawer" hidden>
    <div class="nav-mobile-inner">
      {links.map(link => (
        <a href={link.href} class="nav-mobile-link">{link.label}</a>
      ))}
      <a href={domainLink.href} class="nav-mobile-link nav-mobile-link--domain">{domainLink.label}</a>
      <div class="nav-mobile-divider" />
      <a href="/login"    class="nav-mobile-link">Sign in</a>
      <a href="/contribute" class="nav-mobile-link nav-mobile-link--accent">Contribute</a>
      <a href={otherDomain} class="nav-mobile-link nav-mobile-link--switch">
        Switch to {otherLabel} →
      </a>
    </div>
  </div>
</nav>

<script>
// Highlight the active nav link based on current pathname
const nav = document.getElementById('main-nav');
const domain = nav?.dataset.domain;
const pathname = window.location.pathname;

// Mark the nav link that matches the current path
document.querySelectorAll<HTMLElement>('.gst-navlink').forEach(link => {
  const href = link.getAttribute('href') ?? '';
  if (href === pathname || (href !== '/' && pathname.startsWith(href))) {
    link.dataset.on = '1';
  }
});

// Mobile menu toggle
const toggle = document.getElementById('nav-mobile-toggle');
const drawer = document.getElementById('nav-mobile-drawer');
if (toggle && drawer) {
  toggle.addEventListener('click', () => {
    const open = drawer.hidden !== true;
    drawer.hidden = open;
    toggle.setAttribute('aria-expanded', String(!open));
  });
  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!nav?.contains(e.target as Node) && drawer.hidden === false) {
      drawer.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
    }
  });
}
</script>

<style>
/* Domain switcher — small pill to the right of the wordmark */
.domain-switch {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--sub);
  text-decoration: none;
  padding: 3px 8px 3px 6px;
  border: 1px solid var(--line);
  border-radius: 999px;
  transition: color 0.14s, border-color 0.14s, background 0.14s;
  white-space: nowrap;
  flex-shrink: 0;
}
.domain-switch:hover {
  color: var(--accent);
  border-color: var(--accent);
  background: var(--accent-soft);
}
.domain-switch svg {
  transition: transform 0.2s;
}
.domain-switch:hover svg {
  transform: translateX(2px);
}

/* Nav links */
.gst-navlinks {
  display: flex;
  align-items: center;
  gap: 4px;
}
.gst-navlink {
  color: var(--ink);
  text-decoration: none;
  font-size: 15px;
  opacity: 0.72;
  padding: 6px 12px;
  border-radius: var(--radius);
  transition: opacity 0.14s, color 0.14s, background 0.14s;
  white-space: nowrap;
}
.gst-navlink:hover,
.gst-navlink[data-on='1'] {
  opacity: 1;
  color: var(--accent);
}
.gst-navlink--domain {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  opacity: 0.55;
  border: 1px solid var(--line);
  border-radius: 999px;
  padding: 4px 10px;
}
.gst-navlink--domain:hover,
.gst-navlink--domain[data-on='1'] {
  opacity: 1;
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-soft);
}

/* Ghost + accent buttons */
.gst-ghost {
  color: var(--ink);
  text-decoration: none;
  font-size: 14px;
  opacity: 0.72;
  transition: opacity 0.14s, color 0.14s;
}
.gst-ghost:hover {
  opacity: 1;
  color: var(--accent);
}

/* Mobile toggle — hidden on desktop */
.nav-mobile-toggle {
  display: none;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink);
  padding: 4px;
  border-radius: var(--radius);
}

/* Mobile drawer */
.nav-mobile-drawer {
  border-top: 1px solid var(--line);
  background: var(--bg);
}
.nav-mobile-inner {
  display: flex;
  flex-direction: column;
  padding: 12px 0 16px;
  gap: 2px;
}
.nav-mobile-link {
  display: block;
  padding: 10px 18px;
  font-size: 16px;
  color: var(--ink);
  text-decoration: none;
  border-radius: var(--radius);
  transition: background 0.12s, color 0.12s;
}
.nav-mobile-link:hover {
  background: var(--accent-soft);
  color: var(--accent);
}
.nav-mobile-link--accent {
  background: var(--accent);
  color: var(--accent-ink) !important;
  border-radius: 999px;
  margin: 6px 18px 0;
  text-align: center;
  font-weight: 500;
}
.nav-mobile-link--accent:hover {
  filter: brightness(0.95);
}
.nav-mobile-link--switch {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--sub);
  letter-spacing: 0.5px;
}
.nav-mobile-link--switch:hover {
  color: var(--accent);
}
.nav-mobile-divider {
  height: 1px;
  background: var(--line);
  margin: 8px 18px;
}

/* Mobile breakpoint */
@media (max-width: 768px) {
  .gst-navlinks {
    display: none;
  }
  .gst-navr > .gst-ghost,
  .gst-navr > .btn-accent {
    display: none;
  }
  .nav-mobile-toggle {
    display: flex;
  }
  .domain-switch {
    display: none;
  }
  /* Show domain badge inline in brand on mobile */
  .gst-brand .sub {
    display: none;
  }
}
</style>
