---
import '../styles/global.css';
import { AuthMenu } from '../components/AuthMenu';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Gustale — a digital culinary archive.' } = Astro.props;
const domain = import.meta.env.PUBLIC_DOMAIN ?? 'recipes';
const isGeo = domain === 'geo';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="gst">
    <nav class="gst-nav">
      <div class="wrap gst-nav-in">
        <a href="/" class="gst-brand">
          <span class="gst-wordmark">Gustale</span>
          <span class="sub">{isGeo ? 'Atlas' : 'Recipes'}</span>
        </a>

        <div class="gst-navlinks">
          <a href="/dishes">Dishes</a>
          <a href="/families">Families</a>
          <a href="/lineages">Lineages</a>
          {isGeo && <a href="/map">Map</a>}
          <a href="/about">About</a>
        </div>

        <div class="gst-navr">
          <a href="/dishes/new" class="gst-cta">Contribute</a>
          <AuthMenu client:load />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="gst-foot">
      <div class="wrap">
        <div>
          <div class="fm">Gustale</div>
          <div class="fcap">Open knowledge, slow cooking — {new Date().getFullYear()}</div>
        </div>
        <div class="fcols">
          <div class="fcol">
            <span class="h">Browse</span>
            <a href="/dishes">Dishes</a>
            <a href="/families">Families</a>
            <a href="/lineages">Lineages</a>
          </div>
          <div class="fcol">
            <span class="h">Discover</span>
            <a href="/">Atlas</a>
            {isGeo && <a href="/map">Map</a>}
          </div>
          <div class="fcol">
            <span class="h">About</span>
            <a href="/about">About</a>
            <a href="/dishes/new">Contribute</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
