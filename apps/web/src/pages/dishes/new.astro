---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { NewDishForm } from '../../components/NewDishForm';

// New-dish page. Renders the form as a client-side island because:
//   - The auth check requires the better-auth client session, which lives
//     on api.gustale.com and is not readable from SSR on gustale.com.
//   - The form posts to /api/dishes which needs the session cookie.
// client:load is correct here — `NewDishForm` does NOT touch `window`
// during import (only inside useEffect), so SSR is safe.
---

<Layout
  title="Create a new dish — Gustale"
  description="Add a new dish to the Gustale encyclopedia."
>
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { href: '/dishes', label: 'Dishes' }, { label: 'Add dish' }]} />

  <section class="wrap" style="padding: 48px 0 80px;">
    <header>
      <h1 style="font-family: var(--display); font-size: clamp(36px,5vw,48px); letter-spacing: -1px; margin: 0 0 12px;">
        Add a dish
      </h1>
      <p class="sub" style="margin: 0 0 24px;">
        Drafts are private until a moderator publishes them. You can edit
        and refine the draft before submitting for review.
      </p>
    </header>

    <NewDishForm client:load />
  </section>
</Layout>