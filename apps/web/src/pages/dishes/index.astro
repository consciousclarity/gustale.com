---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { DishExplorer } from '../../components/DishExplorer.tsx';
import ErrorBoundary from '../../components/ErrorBoundary.tsx';
import { listDishes, ApiError } from '../../lib/api';
import type { DishListResponse } from '../../types/dish';

// Server-render the first page of dishes so the initial paint has content
// even if the API is slow or the user has JS disabled.
let initial: DishListResponse = {
  dishes: [],
  limit: 24,
  offset: 0,
};
let serverError: string | null = null;

try {
  initial = await listDishes({ status: 'published', limit: 24 });
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}
---

<Layout title="Dishes — Gustale" description="Browse the Gustale culinary encyclopedia.">
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { label: 'Dishes' }]} />

  <section class="wrap" style="padding: 48px 0 80px;">
    <header>
      <h1>Dishes</h1>
      <p class="sub">
        Explore the encyclopedia. Search, click a card, and follow the story behind each dish.
      </p>
    </header>

    {serverError && (
      <div class="alert alert-warning">
        <strong>Heads up:</strong> the gustale-api could not be reached at build time ({serverError}).
        The page is still rendering — search and pagination will retry against the live API.
      </div>
    )}

    <ErrorBoundary name="Dish list">
      <DishExplorer initial={initial} client:load />
    </ErrorBoundary>
  </section>
</Layout>
