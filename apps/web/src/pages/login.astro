---
import Layout from '../layouts/Layout.astro';
import { SignInForm } from '../components/SignInForm';
---

<Layout title="Sign in — Gustale" description="Sign in to your Gustale account.">
  <div class="auth-page">
    <div class="auth-card">
      <h1 class="auth-card h1">Sign in</h1>
      <p class="auth-card sub">
        Welcome back to Gustale. Sign in to contribute to the encyclopedia.
      </p>

      <div class="gst-card">
        <SignInForm client:load />
      </div>

      <p class="auth-card form-footer">
        Don't have an account?
        <a href="/register" style="color: var(--accent)">
          Create one
        </a>
      </p>
    </div>
  </div>
</Layout>