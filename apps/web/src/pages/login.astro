---
import Layout from '../layouts/Layout.astro';
import { SignInForm } from '../components/SignInForm';
---

<Layout title="Sign in — Gustale" description="Sign in to your Gustale account.">
  <section class="mx-auto max-w-md px-4 py-16">
    <header class="mb-8 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Sign in</h1>
      <p class="mt-2 text-slate-600">
        Welcome back to Gustale. Sign in to contribute to the encyclopedia.
      </p>
    </header>

    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <SignInForm client:load />
    </div>

    <p class="mt-6 text-center text-sm text-slate-500">
      Don't have an account?
      <a href="/register" class="ml-1 font-medium text-emerald-700 hover:text-emerald-800">
        Create one
      </a>
    </p>
  </section>
</Layout>