---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { RegisterForm } from '../components/RegisterForm';
---

<Layout title="Create account — Gustale" description="Create a Gustale contributor account.">
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { label: 'Create account' }]} />
  <div class="auth-page">
    <div class="auth-card">
      <h1 class="auth-card h1">Create account</h1>
      <p class="auth-card sub">
        Free forever. No account required to browse.
      </p>
      <RegisterForm client:load />
    </div>
  </div>
</Layout>
