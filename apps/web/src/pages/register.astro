---
import Layout from '../layouts/Layout.astro';
import { RegisterForm } from '../components/RegisterForm';
---

<Layout title="Create account — Gustale" description="Create a Gustale contributor account.">
  <section class="mx-auto max-w-md px-4 py-16">
    <header class="mb-8 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Create account</h1>
      <p class="mt-2 text-slate-600">
        Join Gustale to contribute to the encyclopedia. We'll send a verification email.
      </p>
    </header>

    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <RegisterForm client:load />
    </div>

    <p class="mt-6 text-center text-sm text-slate-500">
      Already have an account?
      <a href="/login" class="ml-1 font-medium text-emerald-700 hover:text-emerald-800">
        Sign in
      </a>
    </p>
  </section>
</Layout>