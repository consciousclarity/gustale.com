---
import Layout from '../layouts/Layout.astro';
import { RegisterForm } from '../components/RegisterForm';
---

<Layout title="Create account — Gustale" description="Create a Gustale contributor account.">
  <div class="auth-page">
    <div class="auth-card">
      <h1 class="auth-card h1">Create account</h1>
      <p class="auth-card sub">
        Join Gustale to contribute to the encyclopedia. We'll send a verification email.
      </p>

      <div class="gst-card">
        <RegisterForm client:load />
      </div>

      <p class="auth-card form-footer">
        Already have an account?
        <a href="/login" style="color: var(--accent)">
          Sign in
        </a>
      </p>
    </div>
  </div>
</Layout>