---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { ApiError, listDishes } from '../lib/api';
import type { DishListResponse, DishSummary } from '../types/dish';

// Server-render the first paint with all published dishes so we can group
// them by region (origin country, the `originName` field on each dish) on
// the server. If the API is unreachable during build, the page still renders
// and the empty state takes over.
//
// "Region" here means geographic/cultural origin — the country a dish comes
// from. This is the browsing axis that used to live (mixed in) on /families;
// it now has its own page so Families can focus purely on dish form.
let initial: DishListResponse = { dishes: [], limit: 100, offset: 0 };
let serverError: string | null = null;
let totalDishes = 0;

try {
  initial = await listDishes({ status: 'published', limit: 100 });
  totalDishes = initial.dishes.length;
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}

// ── Group dishes by region (origin country) ──────────────────────────────
// originName comes from the API (the dish's origin country). Dishes with no
// origin fall back to "Other".
const groups = new Map<string, DishSummary[]>();
for (const d of initial.dishes) {
  const key = d.originName ?? 'Other';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(d);
}

// Sort regions by member count descending — most-represented origin first,
// then alphabetically for ties so the order is stable build-to-build.
const sortedRegions = [...groups.entries()].sort(
  (a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]),
);
const totalRegions = sortedRegions.length;

// ── Region color dots (consistent per region across the site) ────────────
const REGION_COLORS: Record<string, string> = {
  Argentina: '#8B4513', Austria: '#8B7355', Brazil: '#C2742F', Canada: '#A0522D',
  China: '#B8552F', France: '#6E7F4E', Greece: '#C99A48', Hungary: '#8B7355',
  India: '#D4A853', Indonesia: '#B8552F', Israel: '#C4706B', Italy: '#6E7F4E',
  Japan: '#8B7355', Jordan: '#C99A48', Lebanon: '#D4A853', Mexico: '#B8552F',
  Morocco: '#C2742F', Nepal: '#8B7355', Nigeria: '#8B4513', Peru: '#C4706B',
  Poland: '#8B7355', Portugal: '#6E7F4E', 'Puerto Rico': '#A0522D',
  Singapore: '#C99A48', 'South Korea': '#B8552F', Spain: '#8B7355',
  Thailand: '#C99A48', Tunisia: '#D4A853', Ukraine: '#8B7355',
  'United Kingdom': '#6E7F4E', 'United States': '#A0522D', Vietnam: '#C4706B',
};
function regionColor(r: string): string {
  return REGION_COLORS[r] ?? '#B8552F';
}
---

<Layout
  title="Regions — Gustale"
  description="Browse Gustale's dishes by their geographic origin — explore the cuisines of Greece, Japan, Mexico, Morocco and dozens more, region by region."
>
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { label: 'Regions' }]} />

  {/* ─── Hero ──────────────────────────────────────────────────────── */}
  <section class="fam-hero wrap">
    <p class="eyebrow">
      Browse the atlas · {totalRegions} regions
    </p>
    <h1>
      Where food<br />comes <em>from</em>.
    </h1>
    <p class="sub" style="margin-bottom: 28px;">
      Every dish carries a place. Regions gather the encyclopedia by origin —
      the country and culture a dish was born into — so you can wander one
      cuisine at a time and see what a single place gave the world's table.
    </p>

    <div class="fam-stats">
      <div>
        <b>{totalRegions}</b>
        <span>Regions</span>
      </div>
      <div>
        <b>{totalDishes}</b>
        <span>Dishes</span>
      </div>
    </div>
  </section>

  {/* ─── Filter bar (region only) ─────────────────────────────────── */}
  <div class="fam-filter-bar" id="filter-bar">
    <div class="wrap">
      <div class="inner">

        {/* Region filter */}
        <span class="fb-label">Region</span>
        <div class="fb-chips" id="region-chips">
          <button class="fam-chip active" data-region="all">All<span class="ct">{totalDishes}</span></button>
          {sortedRegions.map(([region, dishes]) => (
            <button class="fam-chip" data-region={region}>
              <span class="dot" style={`background:${regionColor(region)}`}></span>
              {region}
              <span class="ct">{dishes.length}</span>
            </button>
          ))}
        </div>

        <span class="fb-spacer"></span>
        <span class="fb-result" id="region-result">
          Showing <b id="region-count">{totalRegions}</b> regions
        </span>
      </div>
    </div>
  </div>

  {serverError && (
    <div class="wrap" style="padding-top: 24px;">
      <div class="alert alert-warning">
        <strong>Heads up:</strong> the gustale-api could not be reached at build
        time ({serverError}). Showing an empty list — refresh once the API is up.
      </div>
    </div>
  )}

  {/* ─── Region groups ─────────────────────────────────────────────── */}
  {sortedRegions.map(([region, regionDishes]) => (
    <section class="fam-group wrap" data-region={region}>
      <header class="fam-group__head">
        <div>
          <span class="eyebrow">
            <span class="dot" style={`display:inline-block;width:9px;height:9px;border-radius:50%;background:${regionColor(region)};margin-right:7px;`}></span>
            Region
          </span>
          <h2>{region}</h2>
        </div>
        <span class="mono-sub">{regionDishes.length} dishes</span>
      </header>

      <ul class="fam-grid">
        {regionDishes.map((d) => (
          <li>
            <a href={`/dishes/${d.slug}`} class="fam-tile" data-origin={d.originName ?? ''}>
              <h3>{d.canonicalName}</h3>
              {d.shortDescription && <p class="def">{d.shortDescription}</p>}
              <div class="foot">
                <span class="counts mono-sub">{d.originName ?? '—'}</span>
                <span class="go">Explore <span class="arr">→</span></span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  {/* ─── Empty state (shown/hidden by JS) ─────────────────────────── */}
  <div id="empty-state" class="wrap" style="display:none; padding: 60px 0; text-align:center;">
    <p class="sub" style="font-size: 1.1rem; margin-bottom: 20px;">
      No dishes match the selected region.
    </p>
    <button class="btn-outline" id="reset-filters">Clear filter</button>
  </div>

  {/* ─── Closing CTA ───────────────────────────────────────────────── */}
  <section class="wrap" style="padding: 48px 0; text-align: center;">
    <p class="eyebrow">
      See where every region sits
    </p>
    <div style="display:flex; justify-content:center; margin-top:1rem;">
      <a href="/map" class="btn-accent">Open the atlas →</a>
    </div>
  </section>
</Layout>

<script>
  (function () {
    const regionChips = document.querySelectorAll<HTMLButtonElement>('#region-chips .fam-chip');
    const groups      = document.querySelectorAll<HTMLElement>('.fam-group');
    const countEl     = document.getElementById('region-count');
    const emptyState  = document.getElementById('empty-state') as HTMLElement | null;
    const resetBtn    = document.getElementById('reset-filters') as HTMLButtonElement | null;

    let activeRegion = 'all';

    function applyFilters() {
      regionChips.forEach((c) => {
        c.classList.toggle('active', c.dataset.region === activeRegion);
      });

      let visibleRegions = 0;

      groups.forEach((g) => {
        const show = activeRegion === 'all' || g.dataset.region === activeRegion;
        g.style.display = show ? '' : 'none';
        if (show) visibleRegions++;
      });

      if (countEl) countEl.textContent = String(visibleRegions);
      if (emptyState) emptyState.style.display = visibleRegions === 0 ? 'block' : 'none';
    }

    regionChips.forEach((c) => {
      c.addEventListener('click', () => {
        activeRegion = c.dataset.region ?? 'all';
        applyFilters();
      });
    });

    resetBtn?.addEventListener('click', () => {
      activeRegion = 'all';
      applyFilters();
    });
  })();
</script>
