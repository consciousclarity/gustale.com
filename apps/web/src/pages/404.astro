---
import Layout from '../layouts/Layout.astro';

export const prerender = true;

const title = 'Not found — Gustale';
const description = 'The page you are looking for does not exist on Gustale.';
---

<Layout title={title} description={description}>
  <section class="not-found">
    <p class="mono-sub">404</p>
    <h1 class="not-found h1">
      Page not found
    </h1>
    <p>
      The page you are looking for doesn't exist — it may have been renamed,
      moved, or never existed at all.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/dishes"
        class="btn-accent"
      >
        Browse dishes
      </a>
      <a
        href="/map"
        class="btn-ghost"
      >
        View the map
      </a>
    </div>
  </section>
</Layout>