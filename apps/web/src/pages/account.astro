---
import Layout from '../layouts/Layout.astro';
import { AccountPanel } from '../components/AccountPanel';
---

<Layout title="Account — Gustale" description="Manage your Gustale account.">
  <section class="mx-auto max-w-2xl px-4 py-12">
    <header class="mb-6">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Account</h1>
      <p class="mt-2 text-slate-600">
        Your Gustale profile and authentication status.
      </p>
    </header>

    <AccountPanel client:load />
  </section>
</Layout>