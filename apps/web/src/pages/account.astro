---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { AccountPanel } from '../components/AccountPanel';
---

<Layout title="Account — Gustale" description="Manage your Gustale account.">
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { label: 'Account' }]} />
  <section class="wrap" style="padding: 48px 0 80px;">
    <div class="auth-card">
      <h1 class="auth-card h1">Account</h1>
      <p class="auth-card sub">
        Your Gustale profile and authentication status.
      </p>

      <AccountPanel client:load />
    </div>
  </section>
</Layout>
