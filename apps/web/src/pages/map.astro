---
import Layout from '../layouts/Layout.astro';
import { WorldMap } from '../components/WorldMap';
import ErrorBoundary from '../components/ErrorBoundary';
import { getMapDishes, ApiError } from '../lib/api';
import type { MapDish } from '../lib/api';

// Server-render the first paint with real dish coordinates so the globe
// has dots from the moment it appears — the React island only adds
// interactivity (hover, click, projection toggle) on hydration.
let initialDishes: MapDish[] = [];
let serverError: string | null = null;

try {
  const response = await getMapDishes({ limit: 2000 });
  initialDishes = response.dishes;
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}
---

<Layout
  title="Map — Gustale"
  description="Browse Gustale's dishes on an interactive globe by geographic origin."
>
  <section class="mx-auto max-w-6xl space-y-4 px-4 py-10">
    <header>
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">
        World map
      </h1>
      <p class="mt-2 text-slate-600">
        Every dish in Gustale has a place of origin. Spin the globe, scroll to
        zoom in on a region, or click a dot to read about the dish behind it.
      </p>
    </header>

    {serverError && (
      <div class="rounded-md border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
        <strong>Heads up:</strong> the gustale-api could not be reached at build
        time ({serverError}). The globe will retry against the live API after
        hydration.
      </div>
    )}

    <ErrorBoundary name="Map">
      <WorldMap dishes={initialDishes} client:only="react" />
    </ErrorBoundary>

    <p class="text-sm text-slate-500">
      Showing {initialDishes.length} dish{initialDishes.length === 1 ? '' : 'es'} with
      origin coordinates.
      <a href="/dishes" class="ml-2 font-medium text-emerald-700 hover:text-emerald-800">
        View as list →
      </a>
    </p>
  </section>
</Layout>