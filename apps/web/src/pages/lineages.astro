---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { ApiError, listLineages } from '../lib/api';
import type { LineageListResponse, LineageSummary } from '../types/lineage';

// Server-render the first paint with all lineages so filters can hydrate
// from real data. The client island then handles filter chips and search.
// If the API is unreachable during build, the page still renders and
// shows an empty state.
//
// Concept distinction (kept visible in the UI):
//   /families answers: "What kind of dish is this?"
//   /lineages answers: "How did this dish idea travel, evolve, split,
//                       merge, adapt, or reappear across cultures?"
let initial: LineageListResponse = {
  lineages: [],
  totalLineages: 0,
  totalDishes: 0,
  totalRelations: 0,
  uncertainOrParallelCount: 0,
  regions: [],
  techniques: [],
  historicalForces: [],
  confidenceLevels: [],
};
let serverError: string | null = null;

try {
  initial = await listLineages();
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}

// ─── Display labels ─────────────────────────────────────────────────────
const CONFIDENCE_LABELS: Record<string, string> = {
  documented: 'Documented',
  likely: 'Likely related',
  probable: 'Probable',
  possible: 'Possible influence',
  uncertain: 'Uncertain',
  parallel_evolution: 'Parallel evolution',
};

const FORCE_LABELS: Record<string, string> = {
  migration: 'Migration',
  trade_route: 'Trade route',
  empire: 'Empire',
  colonization: 'Colonization',
  diaspora: 'Diaspora',
  religious_exchange: 'Religious exchange',
  port_city_exchange: 'Port city exchange',
  agricultural_spread: 'Agricultural spread',
  technological_change: 'Technological change',
  local_adaptation: 'Local adaptation',
  parallel_evolution: 'Parallel evolution',
  cultural_exchange: 'Cultural exchange',
  nomadic_pastoral: 'Nomadic / pastoral',
  war_and_displacement: 'War & displacement',
};

function labelFor(map: Record<string, string>, key: string): string {
  return map[key] ?? key.split('_').map((s) => s.charAt(0).toUpperCase() + s.slice(1)).join(' ');
}

function confidenceLabel(level: string): string {
  return CONFIDENCE_LABELS[level] ?? level;
}

// ─── Deterministic palette per lineage (visual anchor) ──────────────────
const LINEAGE_PALETTE = [
  '#B8552F', '#6E7F4E', '#C99A48', '#C4706B', '#8B7355',
  '#C2742F', '#D4A853', '#A0522D', '#8B4513', '#7B6F4D',
  '#946847', '#B57A50', '#6E8B74', '#A8806B',
];
function lineageColor(slug: string): string {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) >>> 0;
  return LINEAGE_PALETTE[h % LINEAGE_PALETTE.length];
}

// Sort lineages by displayOrder then by dish count desc so the most
// populated lineages show first (within the "canonical anchors" group).
const sortedLineages = [...initial.lineages].sort(
  (a, b) => a.displayOrder - b.displayOrder,
);

const totalLineages = sortedLineages.length;
const totalDishes = initial.totalDishes;
const totalRelations = initial.totalRelations;
const uncertainCount = initial.uncertainOrParallelCount;

// Helper to slug-ify a force for data-* attributes (kebab-case).
function kebab(s: string): string {
  return s.toLowerCase().replace(/_/g, '-');
}
---

<Layout
  title="Lineages — Gustale"
  description="Explore how dish ideas travel, split, merge, and reappear across cultures — the migration and influence atlas of Gustale."
>
  <Breadcrumbs crumbs={[{ href: '/', label: 'Home' }, { label: 'Lineages' }]} />

  {/* ─── Hero ─────────────────────────────────────────────────────── */}
  <section class="lin-hero wrap">
    <p class="eyebrow">
      Trace the journey · {totalLineages} lineages · {totalDishes} dish links
    </p>
    <h1>
      Every dish belongs<br />to a bigger <em>story</em>.
    </h1>
    <p class="sub">
      Explore how dish ideas travel, split, merge, adapt, and reappear
      across cultures. Lineages trace movement, influence, adaptation —
      and the honest gaps where the record runs out.
    </p>

    {/* ─── Concept explainer: family vs lineage ─────────────────── */}
    <div class="lin-explainer">
      <div class="lin-explainer__col">
        <span class="lin-explainer__label">/families</span>
        <p class="lin-explainer__body">
          Answers <em>“What kind of dish is this?”</em> Form and role —
          dumpling, flatbread, stew. A classification.
        </p>
      </div>
      <div class="lin-explainer__divider"></div>
      <div class="lin-explainer__col">
        <span class="lin-explainer__label lin-explainer__label--accent">/lineages</span>
        <p class="lin-explainer__body">
          Answers <em>“How did this dish idea travel?”</em> Trade,
          migration, diaspora, empire, parallel invention, uncertain
          connection. A story.
        </p>
      </div>
    </div>

    {/* ─── Summary stats ──────────────────────────────────────────── */}
    <div class="lin-stats">
      <div><b>{totalLineages}</b><span>Lineages</span></div>
      <div><b>{totalDishes}</b><span>Dishes mapped</span></div>
      <div><b>{initial.regions.length}</b><span>Regions</span></div>
      <div><b>{initial.historicalForces.length}</b><span>Forces</span></div>
      <div><b>{uncertainCount}</b><span>Uncertain / parallel</span></div>
    </div>
  </section>

  {/* ─── Filter bar ─────────────────────────────────────────────── */}
  <div class="lin-filter-bar" id="lin-filter-bar">
    <div class="wrap">
      <div class="lin-fb-row">
        <input
          type="search"
          id="lin-search"
          class="lin-search"
          placeholder="Search lineages, techniques, regions…"
          autocomplete="off"
        />
      </div>

      {initial.regions.length > 0 && (
        <div class="lin-fb-row">
          <span class="lin-fb-label">Origin / region</span>
          <div class="lin-fb-chips" id="lin-region-chips">
            <button class="lin-chip active" data-region="all">All</button>
            {initial.regions.slice(0, 18).map((r) => (
              <button class="lin-chip" data-region={kebab(r)}>{r}</button>
            ))}
          </div>
        </div>
      )}

      {initial.techniques.length > 0 && (
        <div class="lin-fb-row">
          <span class="lin-fb-label">Technique</span>
          <div class="lin-fb-chips" id="lin-tech-chips">
            <button class="lin-chip active" data-tech="all">All</button>
            {initial.techniques.slice(0, 14).map((t) => (
              <button class="lin-chip" data-tech={kebab(t)}>{t}</button>
            ))}
          </div>
        </div>
      )}

      {initial.historicalForces.length > 0 && (
        <div class="lin-fb-row">
          <span class="lin-fb-label">Historical force</span>
          <div class="lin-fb-chips" id="lin-force-chips">
            <button class="lin-chip active" data-force="all">All</button>
            {initial.historicalForces.map((f) => (
              <button class="lin-chip" data-force={kebab(f)}>{labelFor(FORCE_LABELS, f)}</button>
            ))}
          </div>
        </div>
      )}

      {initial.confidenceLevels.length > 0 && (
        <div class="lin-fb-row">
          <span class="lin-fb-label">Confidence</span>
          <div class="lin-fb-chips" id="lin-conf-chips">
            <button class="lin-chip active" data-conf="all">All</button>
            {initial.confidenceLevels.map((c) => (
              <button class="lin-chip" data-conf={c}>{confidenceLabel(c)}</button>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>

  {serverError && (
    <div class="wrap" style="padding-top: 24px;">
      <div class="alert alert-warning">
        <strong>Heads up:</strong> the gustale-api could not be reached at build
        time ({serverError}). Showing an empty list — refresh once the API is up.
      </div>
    </div>
  )}

  {/* ─── Lineage cards ──────────────────────────────────────────── */}
  <section class="lin-grid wrap" id="lin-grid">
    {sortedLineages.map((lin) => (
      <article
        class="lin-card"
        data-slug={lin.slug}
        data-lineage={lin.slug}
        data-regions={JSON.stringify([...lin.originRegions, ...lin.relatedRegions].map(kebab))}
        data-techniques={JSON.stringify(lin.techniques.map(kebab))}
        data-forces={JSON.stringify(lin.historicalForces.map(kebab))}
        data-conf={lin.confidenceLevel}
        data-search={`${lin.name} ${lin.shortDescription} ${lin.conceptSummary ?? ''} ${lin.techniques.join(' ')} ${lin.originRegions.join(' ')} ${lin.relatedRegions.join(' ')}`.toLowerCase()}
      >
        <header class="lin-card__head">
          <span
            class="lin-card__dot"
            style={`background:${lineageColor(lin.slug)}`}
            aria-hidden="true"
          ></span>
          <span class="lin-card__slug mono-sub">{lin.slug}</span>
          <span class={`lin-card__conf lin-card__conf--${lin.confidenceLevel}`}>
            {confidenceLabel(lin.confidenceLevel)}
          </span>
        </header>
        <h2 class="lin-card__title">
          <a href={`/lineages/${lin.slug}`}>{lin.name}</a>
        </h2>
        {lin.conceptSummary && (
          <p class="lin-card__concept">{lin.conceptSummary}</p>
        )}

        {lin.originSummary && (
          <p class="lin-card__origin">
            <span class="lin-card__origin-label">Origin</span>
            {lin.originSummary}
          </p>
        )}

        {lin.historicalForces.length > 0 && (
          <div class="lin-card__forces">
            {lin.historicalForces.slice(0, 4).map((f) => (
              <span class="lin-pill">{labelFor(FORCE_LABELS, f)}</span>
            ))}
          </div>
        )}

        <div class="lin-card__meta">
          <span><b>{lin.dishCount}</b> dishes</span>
          <span>·</span>
          <span>{lin.originRegions.slice(0, 2).join(', ')}{lin.originRegions.length > 2 ? ` +${lin.originRegions.length - 2}` : ''}</span>
        </div>

        {lin.representativeDishes.length > 0 && (
          <p class="lin-card__reps">
            <span class="lin-card__reps-label">Representative</span>
            {lin.representativeDishes.slice(0, 5).join(' · ')}{lin.representativeDishes.length > 5 ? '…' : ''}
          </p>
        )}

        <a href={`/lineages/${lin.slug}`} class="lin-card__cta">
          Open the lineage <span class="arr">→</span>
        </a>
      </article>
    ))}
  </section>

  {/* ─── Empty state ───────────────────────────────────────────── */}
  <div id="lin-empty" class="wrap" style="display:none; padding: 80px 0; text-align:center;">
    <p class="sub" style="font-size: 1.1rem; margin-bottom: 20px;">
      No lineages match these filters. Try removing one filter or searching
      by technique, region, ingredient, or historical force.
    </p>
    <button class="btn-outline" id="lin-reset">Clear filters</button>
  </div>

  {/* ─── Closing CTA ───────────────────────────────────────────── */}
  <section class="wrap" style="padding: 48px 0; text-align: center;">
    <p class="eyebrow">
      Lineages are best read alongside families and the map
    </p>
    <div style="display:flex; justify-content:center; gap: 16px; margin-top: 1rem; flex-wrap: wrap;">
      <a href="/families" class="btn-outline">Browse by form →</a>
      <a href="/map" class="btn-accent">Open the atlas →</a>
    </div>
  </section>
</Layout>

<script>
  (function () {
    const searchEl    = document.getElementById('lin-search') as HTMLInputElement | null;
    const cards       = Array.from(document.querySelectorAll<HTMLElement>('.lin-card'));
    const emptyState  = document.getElementById('lin-empty') as HTMLElement | null;
    const resetBtn    = document.getElementById('lin-reset') as HTMLButtonElement | null;

    let activeRegion = 'all';
    let activeTech   = 'all';
    let activeForce  = 'all';
    let activeConf   = 'all';
    let activeSearch = '';

    function setChipActive(group: string, value: string) {
      document
        .querySelectorAll<HTMLButtonElement>(`#${group} .lin-chip`)
        .forEach((c) => c.classList.toggle('active', c.dataset[group.replace('lin-', '').replace('-chips', '')] === value));
    }

    function applyFilters() {
      let visible = 0;
      cards.forEach((card) => {
        const regions   = JSON.parse(card.dataset.regions   ?? '[]') as string[];
        const techniques = JSON.parse(card.dataset.techniques ?? '[]') as string[];
        const forces    = JSON.parse(card.dataset.forces    ?? '[]') as string[];
        const conf      = card.dataset.conf ?? '';
        const search    = card.dataset.search ?? '';

        const matchRegion = activeRegion === 'all' || regions.includes(activeRegion);
        const matchTech   = activeTech   === 'all' || techniques.includes(activeTech);
        const matchForce  = activeForce  === 'all' || forces.includes(activeForce);
        const matchConf   = activeConf   === 'all' || conf === activeConf;
        const matchSearch = !activeSearch || search.includes(activeSearch);

        const show = matchRegion && matchTech && matchForce && matchConf && matchSearch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (emptyState) emptyState.style.display = visible === 0 ? 'block' : 'none';
    }

    // Region chips
    document.querySelectorAll<HTMLButtonElement>('#lin-region-chips .lin-chip').forEach((c) => {
      c.addEventListener('click', () => {
        activeRegion = c.dataset.region ?? 'all';
        setChipActive('lin-region-chips', activeRegion);
        applyFilters();
      });
    });
    // Technique chips
    document.querySelectorAll<HTMLButtonElement>('#lin-tech-chips .lin-chip').forEach((c) => {
      c.addEventListener('click', () => {
        activeTech = c.dataset.tech ?? 'all';
        setChipActive('lin-tech-chips', activeTech);
        applyFilters();
      });
    });
    // Force chips
    document.querySelectorAll<HTMLButtonElement>('#lin-force-chips .lin-chip').forEach((c) => {
      c.addEventListener('click', () => {
        activeForce = c.dataset.force ?? 'all';
        setChipActive('lin-force-chips', activeForce);
        applyFilters();
      });
    });
    // Confidence chips
    document.querySelectorAll<HTMLButtonElement>('#lin-conf-chips .lin-chip').forEach((c) => {
      c.addEventListener('click', () => {
        activeConf = c.dataset.conf ?? 'all';
        setChipActive('lin-conf-chips', activeConf);
        applyFilters();
      });
    });

    // Search
    searchEl?.addEventListener('input', () => {
      activeSearch = (searchEl.value ?? '').toLowerCase().trim();
      applyFilters();
    });

    resetBtn?.addEventListener('click', () => {
      activeRegion = 'all';
      activeTech   = 'all';
      activeForce  = 'all';
      activeConf   = 'all';
      activeSearch = '';
      if (searchEl) searchEl.value = '';
      setChipActive('lin-region-chips', 'all');
      setChipActive('lin-tech-chips', 'all');
      setChipActive('lin-force-chips', 'all');
      setChipActive('lin-conf-chips', 'all');
      applyFilters();
    });
  })();
</script>