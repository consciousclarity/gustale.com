---
import Layout from '../layouts/Layout.astro';
import { ApiError, listDishes } from '../lib/api';
import type { DishListResponse, DishSummary } from '../types/dish';

let initial: DishListResponse = { dishes: [], limit: 100, offset: 0 };
let serverError: string | null = null;

try {
  initial = await listDishes({ status: 'published', limit: 100 });
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}

// Group dishes by preparation method (same source as Families).
// Each group becomes one "lineage" — a culinary idea traced across regions.
const groups = new Map<string, DishSummary[]>();
for (const d of initial.dishes) {
  const key = d.methodSlug ?? 'other';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(d);
}

// Sort largest lineage first (most dishes = widest spread)
const sortedGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

// Human-readable lineage names
const LINEAGE_LABELS: Record<string, string> = {
  'poached-in-sauce':       'Poached in sauce',
  'omelettes-and-scrambles':'Omelettes & scrambles',
  'fried-and-topped':       'Fried & topped',
  'steamed-and-custard':    'Steamed & custard',
  'boiled-and-cured':       'Boiled & cured',
  pasta:                    'Pasta',
  'noodle-soup':            'Noodle soups',
  stew:                     'Stews & braises',
  'fried-rice':             'Rice bowls',
  dumpling:                 'Dumplings',
  bread:                    'Breads & doughs',
  pancake:                  'Flatbreads',
  dessert:                  'Sweets & custards',
  curry:                    'Stews & braises',
  kebab:                    'Grilled & skewered',
  salad:                    'Small plates & preserves',
  other:                    'Other preparations',
};

// Provenance narrative for each lineage family
const LINEAGE_STORY: Record<string, string> = {
  'dumpling':
    'A pocket of dough and a filling — the same idea born on trade routes, carried by migration, and reinvented in every kitchen that received it. From Central Asia outward: the dumpling is everywhere.',
  'noodle-soup':
    'Stretched, cut, or rolled dough dropped into broth — a form that follows the Silk Road east and south through every coast it touched. Climate and ingredient swap everything; the logic stays the same.',
  'bread':
    'Fire and grain: the oldest covenant in food. The same flat or leavened disc of dough appears at every latitude where people settled and built ovens.',
  'pancake':
    'The griddle predates the oven. A poured batter, a hot flat surface — this technique crossed deserts and oceans independently, arriving at injera, dosa, blini, and crepe without knowing the others existed.',
  'stew':
    'Slow time and a sealed vessel: patience in cooking has no single origin. The stew is wherever people wait for flavors to merge — clay pot, tagine, cast iron, banana leaf.',
  'curry':
    'Spice, fat, and aromatics ground together as a base — a technique as much as a dish. Trade in pepper, turmeric, and chili wrote the migration routes; the curry shows where those routes led.',
  'pasta':
    'Dried grain shaped into strands or sheets — a technology of preservation and trade. Its travel west from China or east from Persia is debated; its spread across the Mediterranean is history.',
  'omelettes-and-scrambles':
    'The egg as a medium: technique separates every culture\'s answer. Same raw material, wholly different results from Japan\'s tamagoyaki to Tunisia\'s shakshuka to Spain\'s tortilla.',
  'kebab':
    'Meat on heat, over fire — one of the first cooking techniques. The skewer traces nomadic routes across the steppe and down through the Levant, each stop reshaping the cut and the spice.',
  'salad':
    'Small plates assembled from what\'s available: preserved, fermented, or raw. The logic of preservation and contrast appears wherever kitchens needed to stretch ingredients across seasons.',
  'dessert':
    'Sugar, fat, and starch shaped into celebration. Sweet preparations followed trade in cane, honey, and fruit — gifted between courts, carried by merchants, adapted by every cuisine that received them.',
  'fried-rice':
    'Leftover cooked grain meets high heat — a technique born of frugality that became a craft. The wok, the griddle, the clay pot: the method travels with the grain.',
  'other':
    'Preparations that resist easy category — hybrids of technique, crossings of tradition, and dishes that belong to the spaces between lineages.',
};

function labelFor(slug: string): string {
  if (LINEAGE_LABELS[slug]) return LINEAGE_LABELS[slug];
  return slug.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(' ');
}

function storyFor(slug: string): string {
  if (LINEAGE_STORY[slug]) return LINEAGE_STORY[slug];
  return 'A culinary form found across multiple traditions — shaped by the same human impulse, expressed in different kitchens.';
}

// Collect unique origin geo IDs per group (display as placeholder until geo names are resolved)
function regionsFor(_dishes: DishSummary[]): string[] {
  // Region names require a geo lookup — omit tags for now until the list API includes geo names
  return [];
}

const totalLineages = sortedGroups.length;
const totalDishes = initial.dishes.length;
---

<Layout title="Lineages — Gustale">

  {/* ── Hero ── */}
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-12 md:pt-24">
    <p class="mb-3 font-mono text-xs font-medium tracking-widest text-[#B8552F] uppercase">
      By provenance · {totalLineages} lineages
    </p>
    <h1 class="font-serif text-4xl leading-tight text-slate-900 md:text-6xl md:leading-[1.08]">
      The paths food <em class="font-serif italic not-italic" style="font-style:italic">travels</em>.
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-600">
      Before a dish has a name, it has a lineage — an idea that crossed a border, changed hands,
      and arrived somewhere new wearing different clothes. Lineages trace those journeys.
    </p>

    <div class="mt-8 flex gap-8">
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">{totalLineages}</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Lineages</div>
      </div>
      <div class="w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">{totalDishes}</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Dishes</div>
      </div>
      <div class="w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">26</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Regions</div>
      </div>
    </div>
  </section>

  {/* ── Three pillars callout ── */}
  <section class="border-y border-slate-100 bg-slate-50">
    <div class="mx-auto grid max-w-5xl grid-cols-3 divide-x divide-slate-200 px-4">
      <a href="/" class="group flex flex-col gap-1 px-6 py-5 transition hover:bg-white">
        <span class="font-mono text-[10px] tracking-widest text-slate-400 uppercase">By place</span>
        <span class="font-medium text-slate-700 group-hover:text-slate-900">Atlas</span>
      </a>
      <a href="/families" class="group flex flex-col gap-1 px-6 py-5 transition hover:bg-white">
        <span class="font-mono text-[10px] tracking-widest text-slate-400 uppercase">By form</span>
        <span class="font-medium text-slate-700 group-hover:text-slate-900">Families</span>
      </a>
      <div class="flex flex-col gap-1 px-6 py-5 bg-white">
        <span class="font-mono text-[10px] tracking-widest text-[#B8552F] uppercase">By provenance</span>
        <span class="font-semibold text-slate-900">Lineages</span>
      </div>
    </div>
  </section>

  {serverError && (
    <div class="mx-auto max-w-5xl px-4 py-4">
      <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
        <strong>Note:</strong> the API was unreachable at build time ({serverError}). Showing empty data.
      </div>
    </div>
  )}

  {/* ── Lineage cards ── */}
  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="grid gap-6 md:grid-cols-2">
      {sortedGroups.map(([slug, dishes], i) => {
        const regions = regionsFor(dishes);
        return (
          <article class="group relative flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white transition hover:border-slate-300 hover:shadow-md hover:shadow-slate-100">
            {/* Header strip */}
            <div class="border-b border-slate-100 px-6 pt-6 pb-5">
              <div class="mb-1 flex items-center justify-between">
                <span class="font-mono text-[10px] tracking-widest text-slate-400 uppercase">
                  {slug}
                </span>
                <span class="font-mono text-[11px] text-slate-400">
                  {dishes.length} dishes
                </span>
              </div>
              <h2 class="text-xl font-semibold text-slate-900">{labelFor(slug)}</h2>
            </div>

            {/* Story */}
            <div class="flex flex-1 flex-col gap-4 px-6 py-5">
              <p class="text-sm leading-relaxed text-slate-600">
                {storyFor(slug)}
              </p>

              {regions.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {regions.map(r => (
                    <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-0.5 font-mono text-[10px] text-slate-500">
                      {r}
                    </span>
                  ))}
                </div>
              )}
            </div>

            {/* Dish list preview */}
            <ul class="border-t border-slate-100 divide-y divide-slate-50">
              {dishes.slice(0, 3).map(d => (
                <li>
                  <a
                    href={`/dishes/${d.slug}`}
                    class="flex items-center justify-between px-6 py-3 text-sm transition hover:bg-slate-50"
                  >
                    <span class="font-medium text-slate-800">{d.canonicalName}</span>
                    <span class="font-mono text-[11px] text-slate-400">→</span>
                  </a>
                </li>
              ))}
              {dishes.length > 3 && (
                <li>
                  <a
                    href="/families"
                    class="flex items-center justify-between px-6 py-3 text-sm text-slate-400 transition hover:bg-slate-50 hover:text-slate-600"
                  >
                    <span>{dishes.length - 3} more in this lineage</span>
                    <span class="font-mono text-[11px]">→</span>
                  </a>
                </li>
              )}
            </ul>
          </article>
        );
      })}
    </div>
  </section>

  {/* ── Closing CTA ── */}
  <section class="mx-auto max-w-5xl px-4 pb-20 pt-4">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-8 py-10 text-center">
      <p class="font-mono text-xs tracking-widest text-slate-400 uppercase">Every lineage lives on the map</p>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900">See where each lineage spread.</h2>
      <p class="mt-2 text-sm text-slate-500">Open the atlas and follow the migration routes yourself.</p>
      <a
        href="/map"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700"
      >
        Open the atlas →
      </a>
    </div>
  </section>
</Layout>
