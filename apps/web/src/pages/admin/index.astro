---
/**
 * /admin — Admin dashboard (control center).
 *
 * The shell (sidebar + top bar) is AdminLayout. The dashboard content is
 * the <AdminDashboard /> React island, which fetches real data
 * client-side from /api/admin/stats (with a graceful fallback to
 * /api/admin/dishes + /api/admin/lookups). Admin pages ship as static
 * HTML; access is gated by src/middleware.ts and by the admin API.
 */
import AdminLayout from '../../layouts/AdminLayout.astro';
import { AdminDashboard } from '../../components/admin/AdminDashboard';
---

<AdminLayout
  title="Admin — Gustale"
  pageTitle="Dashboard"
  active="dashboard"
  description="Gustale admin control panel — manage dishes, taxonomy and provenance."
>
  <AdminDashboard client:load />
</AdminLayout>
