---
import Layout from '../layouts/Layout.astro';
import { ApiError, listDishes } from '../lib/api';
import type { DishListResponse, DishSummary } from '../types/dish';

// Server-render the first paint with all published dishes so we can
// group them by method/family on the server. Same fallback pattern as
// the dish list page — if the API is unreachable during build, the page
// still renders and the client island takes over with a live fetch.
let initial: DishListResponse = { dishes: [], limit: 100, offset: 0 };
let serverError: string | null = null;
let totalDishes = 0;

try {
  initial = await listDishes({ status: 'published', limit: 100 });
  totalDishes = initial.dishes.length;
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}

// Group dishes by preparation method (the "family"). Dishes without a
// method go into "Other". Sort groups by member count descending —
// most-shared form first.
const groups = new Map<string, DishSummary[]>();
for (const d of initial.dishes) {
  const key = d.methodSlug ?? 'other';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(d);
}

const sortedGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

// Family display names — match the seed-data slugs. Unknown slugs fall
// back to a Title-Cased version of the slug.
const FAMILY_LABELS: Record<string, string> = {
  'poached-in-sauce': 'Poached in sauce',
  'omelettes-and-scrambles': 'Omelettes & scrambles',
  'fried-and-topped': 'Fried & topped',
  'steamed-and-custard': 'Steamed & custard',
  'boiled-and-cured': 'Boiled & cured',
  pasta: 'Pasta',
  'noodle-soup': 'Noodle soups',
  stew: 'Stews & braises',
  'fried-rice': 'Rice bowls',
  dumpling: 'Dumplings',
  bread: 'Breads & doughs',
  pancake: 'Flatbreads',
  dessert: 'Sweets & custards',
  curry: 'Stews & braises',
  kebab: 'Grilled & skewered',
  salad: 'Small plates & preserves',
  other: 'Other',
};

// Color dots per family — matches the Atlas island palette
const FAMILY_COLORS: Record<string, string> = {
  'poached-in-sauce': '#C2742F',
  'omelettes-and-scrambles': '#C2742F',
  'fried-and-topped': '#A0522D',
  'steamed-and-custard': '#C99A48',
  'boiled-and-cured': '#8B7355',
  pasta: '#6E7F4E',
  'noodle-soup': '#8B7355',
  stew: '#A0522D',
  'fried-rice': '#C9A849',
  dumpling: '#C99A48',
  bread: '#D4A853',
  pancake: '#D4A853',
  dessert: '#C4706B',
  curry: '#B8542A',
  kebab: '#A0522D',
  salad: '#7A8B5C',
  other: '#6B6052',
};

function labelFor(slug: string): string {
  if (FAMILY_LABELS[slug]) return FAMILY_LABELS[slug];
  return slug
    .split('-')
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join(' ');
}

function colorFor(slug: string): string {
  return FAMILY_COLORS[slug] ?? '#B8552F';
}

const totalFamilies = sortedGroups.length;
---

<Layout
  title="Families — Gustale"
  description="Browse Gustale's dishes grouped by the form they take — dumplings, flatbreads, eggs, noodles, and more."
>
  {/* ─── Hero ──────────────────────────────────────────────────────── */}
  <section class="fam-hero wrap">
    <p class="eyebrow">
      Browse the atlas · {totalFamilies} families
    </p>
    <h1>
      The shapes<br />food <em>takes</em>.
    </h1>
    <p class="sub" style="margin-bottom: 28px;">
      Before a dish has a country, it has a form — a dumpling, a flatbread,
      an egg gently cooked. Families gather those forms across the world,
      so you can see how one idea is told in a hundred kitchens.
    </p>

    <div class="fam-stats">
      <div>
        <b>{totalFamilies}</b>
        <span>Families</span>
      </div>
      <div>
        <b>{totalDishes}</b>
        <span>Dishes</span>
      </div>
      <div>
        <b>26</b>
        <span>Max regions</span>
      </div>
    </div>
  </section>

  {/* ─── Filter bar ─────────────────────────────────────────────── */}
  <div class="fam-filter-bar">
    <div class="wrap">
      <div class="inner">
        <span class="fb-label">Filter by family</span>

        {/* All chip */}
        <button class="fam-chip" data-family="all" data-on="1">
          All
          <span class="ct">{totalDishes}</span>
        </button>

        {/* Per-family chips */}
        {sortedGroups.map(([slug, dishes]) => (
          <button class="fam-chip" data-family={slug} data-on="0">
            <span class="dot" style={`background:${colorFor(slug)}`}></span>
            {labelFor(slug)}
            <span class="ct">{dishes.length}</span>
          </button>
        ))}

        <span class="fb-spacer"></span>
        <span class="fb-result" id="fam-result">
          Showing <b id="fam-count">{totalFamilies}</b> families
        </span>
      </div>
    </div>
  </div>

  {serverError && (
    <div class="wrap" style="padding-top: 24px;">
      <div class="alert alert-warning">
        <strong>Heads up:</strong> the gustale-api could not be reached at build
        time ({serverError}). Showing an empty list — refresh once the API is up.
      </div>
    </div>
  )}

  {/* ─── Family groups ─────────────────────────────────────────────── */}
  {sortedGroups.map(([slug, dishes]) => (
    <section class="fam-group wrap" data-family={slug}>
      <header class="fam-group__head">
        <div>
          <span class="eyebrow">{slug}</span>
          <h2>{labelFor(slug)}</h2>
        </div>
        <span class="mono-sub">{dishes.length} dishes</span>
      </header>

      <ul class="fam-grid">
        {dishes.map((d) => (
          <li>
            <a href={`/dishes/${d.slug}`} class="fam-tile">
              <h3>{d.canonicalName}</h3>
              {d.shortDescription && <p class="def">{d.shortDescription}</p>}
              <div class="foot">
                <span class="counts mono-sub">{d.country ?? d.region ?? '—'}</span>
                <span class="go">Explore <span class="arr">→</span></span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  {/* ─── Closing CTA ───────────────────────────────────────────────── */}
  <section class="wrap" style="padding: 48px 0; text-align: center;">
    <p class="eyebrow">
      Every family lives on the map
    </p>
    <div style="display:flex; justify-content:center; margin-top:1rem;">
      <a href="/map" class="btn-accent">Open the atlas →</a>
    </div>
  </section>
</Layout>

<script>
  (function () {
    const chips = document.querySelectorAll<HTMLButtonElement>('.fam-chip');
    const groups = document.querySelectorAll<HTMLElement>('.fam-group');
    const countEl = document.getElementById('fam-count');

    function setFilter(family: string) {
      // Update chip active states
      chips.forEach((c) => {
        c.dataset.on = c.dataset.family === family ? '1' : '0';
      });

      // Show/hide groups
      let visible = 0;
      groups.forEach((g) => {
        const match = family === 'all' || g.dataset.family === family;
        g.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      // Update count
      if (countEl) {
        countEl.textContent = String(visible);
      }
    }

    chips.forEach((c) => {
      c.addEventListener('click', () => {
        setFilter(c.dataset.family ?? 'all');
      });
    });
  })();
</script>
