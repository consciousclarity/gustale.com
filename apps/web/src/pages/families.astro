---
import Layout from '../layouts/Layout.astro';
import { ApiError, listDishes } from '../lib/api';
import type { DishListResponse, DishSummary } from '../types/dish';

// Server-render the first paint with all published dishes so we can
// group them by method/family on the server. Same fallback pattern as
// the dish list page — if the API is unreachable during build, the page
// still renders and the client island takes over with a live fetch.
let initial: DishListResponse = { dishes: [], limit: 100, offset: 0 };
let serverError: string | null = null;
let totalDishes = 0;

try {
  initial = await listDishes({ status: 'published', limit: 100 });
  totalDishes = initial.dishes.length;
} catch (err: unknown) {
  if (err instanceof ApiError) {
    serverError = `API ${err.status} — check that gustale-api is reachable from the build.`;
  } else if (err instanceof Error) {
    serverError = err.message;
  } else {
    serverError = 'Unknown error';
  }
}

// Group dishes by preparation method (the "family"). Dishes without a
// method go into "Other". Sort groups by member count descending —
// most-shared form first.
const groups = new Map<string, DishSummary[]>();
for (const d of initial.dishes) {
  const key = d.methodSlug ?? 'other';
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(d);
}

const sortedGroups = [...groups.entries()].sort((a, b) => b[1].length - a[1].length);

// Family display names — match the seed-data slugs. Unknown slugs fall
// back to a Title-Cased version of the slug.
const FAMILY_LABELS: Record<string, string> = {
  'poached-in-sauce': 'Poached in sauce',
  'omelettes-and-scrambles': 'Omelettes & scrambles',
  'fried-and-topped': 'Fried & topped',
  'steamed-and-custard': 'Steamed & custard',
  'boiled-and-cured': 'Boiled & cured',
  pasta: 'Pasta',
  'noodle-soup': 'Noodle soups',
  stew: 'Stews & braises',
  'fried-rice': 'Rice bowls',
  dumpling: 'Dumplings',
  bread: 'Breads & doughs',
  pancake: 'Flatbreads',
  dessert: 'Sweets & custards',
  curry: 'Stews & braises',
  kebab: 'Grilled & skewered',
  salad: 'Small plates & preserves',
  other: 'Other',
};

function labelFor(slug: string): string {
  if (FAMILY_LABELS[slug]) return FAMILY_LABELS[slug];
  return slug
    .split('-')
    .map((s) => s.charAt(0).toUpperCase() + s.slice(1))
    .join(' ');
}

const totalFamilies = sortedGroups.length;
---

<Layout
  title="Families — Gustale"
  description="Browse Gustale's dishes grouped by the form they take — dumplings, flatbreads, eggs, noodles, and more."
>
  {/* ── Hero ── */}
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-12 md:pt-24">
    <p class="mb-3 font-mono text-xs font-medium tracking-widest text-[#B8552F] uppercase">
      Browse the atlas · {totalFamilies} families
    </p>
    <h1 class="font-serif text-4xl leading-tight text-slate-900 md:text-6xl md:leading-[1.08]">
      The shapes<br />food <em class="font-serif italic" style="font-style:italic">takes</em>.
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-600">
      Before a dish has a country, it has a form — a dumpling, a flatbread,
      an egg gently cooked. Families gather those forms across the world,
      so you can see how one idea is told in a hundred kitchens.
    </p>

    <div class="mt-8 flex gap-8">
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">{totalFamilies}</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Families</div>
      </div>
      <div class="w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">{totalDishes}</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Dishes</div>
      </div>
      <div class="w-px bg-slate-200"></div>
      <div>
        <div class="text-3xl font-semibold tabular-nums text-slate-900">26</div>
        <div class="mt-0.5 font-mono text-[11px] tracking-widest text-slate-400 uppercase">Regions</div>
      </div>
    </div>
  </section>

  {/* ── Three pillars callout ── */}
  <section class="border-y border-slate-100 bg-slate-50">
    <div class="mx-auto grid max-w-5xl grid-cols-3 divide-x divide-slate-200 px-4">
      <a href="/" class="group flex flex-col gap-1 px-6 py-5 transition hover:bg-white">
        <span class="font-mono text-[10px] tracking-widest text-slate-400 uppercase">By place</span>
        <span class="font-medium text-slate-700 group-hover:text-slate-900">Atlas</span>
      </a>
      <div class="flex flex-col gap-1 px-6 py-5 bg-white">
        <span class="font-mono text-[10px] tracking-widest text-[#B8552F] uppercase">By form</span>
        <span class="font-semibold text-slate-900">Families</span>
      </div>
      <a href="/lineages" class="group flex flex-col gap-1 px-6 py-5 transition hover:bg-white">
        <span class="font-mono text-[10px] tracking-widest text-slate-400 uppercase">By provenance</span>
        <span class="font-medium text-slate-700 group-hover:text-slate-900">Lineages</span>
      </a>
    </div>
  </section>

  {serverError && (
    <div class="mx-auto max-w-5xl px-4 py-4">
      <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
        <strong>Heads up:</strong> the gustale-api could not be reached at build
        time ({serverError}). Showing an empty list — refresh once the API is up.
      </div>
    </div>
  )}

  {/* ── Family groups — full dish grid per family ── */}
  {sortedGroups.map(([slug, dishes]) => (
    <section class="mx-auto max-w-5xl px-4 py-10">
      <header class="mb-6 flex items-end justify-between border-b border-slate-100 pb-3">
        <div>
          <p class="mb-1 font-mono text-[10px] tracking-widest text-slate-400 uppercase">
            {slug}
          </p>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 md:text-3xl">
            {labelFor(slug)}
          </h2>
        </div>
        <span class="font-mono text-[11px] tracking-widest text-slate-400 uppercase">
          {dishes.length} {dishes.length === 1 ? 'dish' : 'dishes'}
        </span>
      </header>

      <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {dishes.map((d) => (
          <li>
            <a
              href={`/dishes/${d.slug}`}
              class="group flex h-full flex-col rounded-xl border border-slate-200 bg-white p-5 transition hover:border-slate-300 hover:shadow-md hover:shadow-slate-100"
            >
              <h3 class="text-base font-semibold text-slate-900 group-hover:text-[#B8552F]">
                {d.canonicalName}
              </h3>
              {d.shortDescription && (
                <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">
                  {d.shortDescription}
                </p>
              )}
              <div class="mt-4 flex items-center justify-between">
                <span class="font-mono text-[11px] tracking-widest text-slate-400 uppercase">
                  Explore
                </span>
                <span class="font-mono text-sm text-slate-400 transition group-hover:text-[#B8552F] group-hover:translate-x-0.5">
                  →
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  {/* ── Closing CTA ── */}
  <section class="mx-auto max-w-5xl px-4 pb-20 pt-4">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-8 py-10 text-center">
      <p class="font-mono text-xs tracking-widest text-slate-400 uppercase">
        Every family lives on the map
      </p>
      <h2 class="mt-3 text-2xl font-semibold text-slate-900">
        See where each form spread.
      </h2>
      <p class="mt-2 text-sm text-slate-500">
        Open the atlas and follow the forms across continents.
      </p>
      <a
        href="/map"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700"
      >
        Open the atlas →
      </a>
    </div>
  </section>
</Layout>
