NODE_ENV=development
HOST=127.0.0.1
PORT=4000
LOG_LEVEL=debug

# Postgres (Drizzle uses postgres-js connection string)
DATABASE_URL=postgresql://app:CHANGEME@127.0.0.1:5432/gustale

# CORS — Astro dev server
CORS_ORIGIN=http://localhost:4321

# Session secret (min 32 chars) — generate with: openssl rand -hex 32
SESSION_SECRET=CHANGEME-32-CHAR-MINIMUM-SECRET-FOR-BETTER-AUTH

# MinIO
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=CHANGEME
MINIO_SECRET_KEY=CHANGEME
MINIO_BUCKET_PUBLIC=gustale-public
MINIO_BUCKET_PRIVATE=gustale-media
