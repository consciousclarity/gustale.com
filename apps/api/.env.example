NODE_ENV=development
HOST=127.0.0.1
PORT=4000
LOG_LEVEL=debug

# Postgres — defaults match .devcontainer/docker-compose.yml
# User: gustale / Password: gustale_dev / Database: gustale
DATABASE_URL=postgresql://gustale:gustale_dev@127.0.0.1:5432/gustale

# CORS — Astro dev server
CORS_ORIGIN=http://localhost:4321

# Session secret (min 32 chars) — generate with: openssl rand -hex 32
SESSION_SECRET=CHANGEME-32-CHAR-MINIMUM-SECRET-FOR-BETTER-AUTH

# MinIO — defaults match .devcontainer/docker-compose.yml
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=gustale_dev
MINIO_SECRET_KEY=gustale_dev_password
MINIO_BUCKET_PUBLIC=gustale-public
MINIO_BUCKET_PRIVATE=gustale-media
