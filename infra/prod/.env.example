NODE_ENV=production
HOST=127.0.0.1
PORT=4000
LOG_LEVEL=info

# Postgres — connects to the shared-postgres container on the host via 127.0.0.1
DATABASE_URL=postgresql://gustale:__GUSTALE_DB_PASSWORD__@127.0.0.1:5432/gustale

# CORS — for now, only the API host itself + localhost dev
CORS_ORIGIN=https://api.gustale.com,https://gustale.com,https://www.gustale.com

# Session secret (32+ chars) — for Fastify / Fastify cookies if used
SESSION_SECRET=__SESSION_SECRET__

# MinIO (shared stack on the host, port 9000)
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=__MINIO_ROOT_USER__
MINIO_SECRET_KEY=__MINIO_ROOT_PASSWORD__
MINIO_BUCKET_PUBLIC=gustale-public
MINIO_BUCKET_PRIVATE=gustale-media

# Better-auth
BETTER_AUTH_URL=https://api.gustale.com
BETTER_AUTH_SECRET=__BETTER_AUTH_SECRET__
# GOOGLE_CLIENT_ID=        # optional
# GOOGLE_CLIENT_SECRET=    # optional
# RESEND_API_KEY=          # optional
