# ─── Dependencies ─────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.pnp.*
.yarn/
*.lockb

# ─── Build output ─────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo

# ─── Backups / temp ───────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.DS_Store
Thumbs.db
.vscode/
.idea/

# ─── Cache / coverage ────────────────────────────────────────────────
.cache/
.turbo/
.parcel-cache/
.eslintcache
*.lcov
coverage/
.nyc_output/

# ─── Logs ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
logs/

# ─── Secrets — NEVER commit these ────────────────────────────────────
# .env files (any depth, any name except .env.example)
.env
.env.*
!.env.example

# SSH / TLS / signing material
*.pem
*.key
*.crt
*.csr
id_rsa*
id_ed25519*
known_hosts*

# MinIO / S3 state
.minio-data/
.minio.sys/

# Postgres dumps
*.sql.gz
*.sql.bz2
*.dump

# ─── Tooling: Docker ─────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── Tooling: editor / OS ────────────────────────────────────────────
.swc/
*.swp
*.swo
*~
.fuse_hidden*

# ─── Repo-specific: monorepo build artifacts ─────────────────────────
# Database package: generated SQL and dist should be committed;
# .bak directories must NEVER be.
packages/db/dist/
packages/db/dist.bak/
packages/db/.drizzle-tmp/

# Test artefacts
apps/api/test/.tmp/
apps/api/test/__snapshots__/*.snap.tmp

# ─── Project notes (webmaster-only, not for git) ───────────────────
# project-data/ contains handoff dumps and personal notes. Do not commit.
project-data/
logs.zip

# .hermes/ contains agent-shared state files (SHARED_STATE.md, TASKS.md)
# and Hermes-specific notes. Keep local-only — Hermes syncs them out-of-band.
# CLAUDE.md (sibling) IS committed so Claude Code picks it up automatically.
.hermes/
*.log.zip
.swarm/
.claude-flow/
ruvector.db
*.ruvector.db
# Holds provider API keys in PLAINTEXT — never commit.
claude-flow.config.json
apps/api/deploy/
